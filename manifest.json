{
  "id": "/",

  "name": "Examia — Ace Your Exams",
  "short_name": "Examia",

  "description": "Examia is an offline exam planning and Pomodoro study companion designed to help students organise exams, track study progress, manage schedules, and stay focused.",

  "start_url": "/index.html?source=pwa",
  "scope": "/",

  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://examia.navahue.workers.dev"
    }
  ],

  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],

  "orientation": "portrait-primary",

  "background_color": "#F0F4F8",
  "theme_color": "#5BA4CF",

  "lang": "en-US",
  "dir": "ltr",

  "categories": [
    "education",
    "productivity",
    "utilities"
  ],

  "prefer_related_applications": false,

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "handle_links": "preferred",

  "edge_side_panel": {
    "preferred_width": 420
  },

  "note_taking": {
    "new_note_url": "/index.html#planner"
  },

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "icons": [
    { "src": "icon-72.png",  "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "icon-96.png",  "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "icon-128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "icon-144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "icon-152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" }
  ],

  "screenshots": [
    {
      "src": "splash.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Examia — Dashboard overview on mobile"
    },
    {
      "src": "splash-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Examia — Dashboard overview on desktop"
    }
  ],

  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Overview of your exams, study progress, and upcoming sessions",
      "url": "/index.html#dashboard",
      "icons": [{ "src": "icon-dashboard.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Exam Planner",
      "short_name": "Planner",
      "description": "Plan and manage your upcoming exams",
      "url": "/index.html#planner",
      "icons": [{ "src": "icon-planner.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Study Tracker",
      "short_name": "Tracker",
      "description": "Track your study progress per exam",
      "url": "/index.html#tracker",
      "icons": [{ "src": "icon-tracker.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Pomodoro Timer",
      "short_name": "Pomodoro",
      "description": "Start a focused Pomodoro session",
      "url": "/index.html#pomodoro",
      "icons": [{ "src": "icon-pomodoro.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Motivation",
      "short_name": "Motivation",
      "description": "Get a motivational quote to keep going",
      "url": "/index.html#motivation",
      "icons": [{ "src": "icon-motivation.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],

  "share_target": {
    "action": "/index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+examia",
      "url": "/index.html?open=%s"
    }
  ],

  "file_handlers": [
    {
      "action": "/index.html",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt"]
      }
    }
  ],

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://examia.navahue.workers.dev/manifest.json"
    }
  ],

  "widgets": [
    {
      "name": "Pomodoro Timer",
      "short_name": "Pomodoro",
      "description": "Quick-launch the Pomodoro focus timer",
      "tag": "pomodoro-widget",
      "msAcTemplate": "/widgets/pomodoro.json",
      "data": "/widgets/pomodoro-data.json",
      "type": "application/json",
      "screenshots": [
        { "src": "splash.png", "sizes": "1080x1920", "type": "image/png", "label": "Pomodoro Timer Widget" }
      ],
      "icons": [
        { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" }
      ],
      "auth": false,
      "update": 900
    },
    {
      "name": "Upcoming Exams",
      "short_name": "Exams",
      "description": "See your next exam at a glance",
      "tag": "exams-widget",
      "msAcTemplate": "/widgets/exams.json",
      "data": "/widgets/exams-data.json",
      "type": "application/json",
      "screenshots": [
        { "src": "splash.png", "sizes": "1080x1920", "type": "image/png", "label": "Upcoming Exams Widget" }
      ],
      "icons": [
        { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" }
      ],
      "auth": false,
      "update": 3600
    }
  ]
}