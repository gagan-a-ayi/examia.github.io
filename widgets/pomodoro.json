{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://examia.navahue.workers.dev/icon-96.png",
                  "width": "28px",
                  "height": "28px",
                  "style": "person"
                }
              ],
              "verticalContentAlignment": "Center"
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "EXAMIA POMODORO",
                  "size": "Small",
                  "weight": "Bolder",
                  "color": "Accent",
                  "spacing": "None"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "${mode}",
          "size": "Small",
          "weight": "Bolder",
          "color": "Accent",
          "horizontalAlignment": "Center",
          "spacing": "None"
        },
        {
          "type": "TextBlock",
          "text": "${timeDisplay}",
          "size": "ExtraLarge",
          "weight": "Bolder",
          "horizontalAlignment": "Center",
          "spacing": "Small",
          "fontType": "Monospace"
        },
        {
          "type": "TextBlock",
          "text": "${statusMessage}",
          "size": "Small",
          "isSubtle": true,
          "horizontalAlignment": "Center",
          "spacing": "None",
          "wrap": true
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🔥 Streak",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                },
                {
                  "type": "TextBlock",
                  "text": "${streak} days",
                  "size": "Medium",
                  "weight": "Bolder",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "✅ Today",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                },
                {
                  "type": "TextBlock",
                  "text": "${sessionsToday} sessions",
                  "size": "Medium",
                  "weight": "Bolder",
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "▶ Open Timer",
      "verb": "open-pomodoro",
      "style": "positive"
    }
  ]
}